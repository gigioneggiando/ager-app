# Mobile app environment. Copy to `.env` (or `.env.local`) for local development.
# Only variables prefixed with EXPO_PUBLIC_ are inlined into the client bundle.

# Backend base URL the app talks to. Defaults to production when unset.
# Local backend example (Android emulator reaches the host via 10.0.2.2):
#   EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:8080
# iOS simulator / Expo Go on the same machine:
#   EXPO_PUBLIC_API_BASE_URL=http://localhost:8080
EXPO_PUBLIC_API_BASE_URL=https://api.agerculture.com
