# Backend API base URL — SERVER-ONLY. Used by the Next route handlers that proxy the
# backend (e.g. /api/feed, and auth/CSRF later). Never exposed to the browser.
# Defaults to production if unset; override for local backend dev.
API_BASE_URL=https://api.agerculture.com

# Optional: backend base URL exposed to the BROWSER. Only needed if some value must be
# read client-side. The feed (and other backend calls) go through the server-side proxy
# above, so this is not required for the feed.
# NEXT_PUBLIC_API_BASE_URL=https://api.agerculture.com
